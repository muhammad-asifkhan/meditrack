# ─────────────────────────────────────
# MediTrack Environment Configuration
# Copy this file to .env and fill in values
# ─────────────────────────────────────

# Database
DB_NAME=meditrack                          # PostgreSQL database name
DB_USER=meditrack_user                     # PostgreSQL username
DB_PASSWORD=meditrack_secret_2024          # PostgreSQL password (CHANGE IN PRODUCTION)

# API
NODE_ENV=development                       # Node environment: development|production
API_PORT=3001                              # Port for the Express API server

# Auth Secrets (MUST change in production — use 64-char random strings)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production

# Frontend
VITE_API_URL=http://localhost:3001         # URL frontend uses to reach the API
FRONTEND_URL=http://localhost:5173         # Allowed CORS origin

# Seeder
SEED_DB=true                              # Set to true to auto-seed on first start
